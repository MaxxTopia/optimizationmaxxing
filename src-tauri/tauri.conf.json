{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "optimizationmaxxing",
  "version": "0.1.67",
  "identifier": "com.maxxers.optimizationmaxxing",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "optimizationmaxxing",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "visible": false
      },
      {
        "label": "splash",
        "url": "splash.html",
        "width": 360,
        "height": 360,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "center": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/lhm/*.dll",
      "resources/lhm/read_sensors.ps1",
      "resources/scripts/clear_standby.ps1"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/MaxxTopia/optimizationmaxxing/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJCQ0QxMjM1MTRERTkzQ0QKUldUTms5NFVOUkxOdTBxWER0UTFONUFVVmNWMTBXZk84Z0JJVWlqVWloYU53YzhTU2w3Q2tkb24K"
    }
  }
}

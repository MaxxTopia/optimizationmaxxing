{
  "name": "Competitive FPS Pure",
  "glyph": "🏆",
  "tagline": "Maximum input fidelity · ranked + tournament rigs",
  "description": "Single-purpose competitive FPS preset. Strips every background latency source: telemetry, indexer, DVR, mouse acceleration, USB selective-suspend, Cortana, widgets. Maxes scheduler bias to focused window. NOT for laptops or daily-driver rigs.",
  "tweakIds": [
    "ui.gamedvr.disable",
    "ui.gamedvr.appcapture.disable",
    "ui.fse.disable-global",
    "ui.mouse.disable-acceleration",
    "ui.mouse.disable-trails",
    "ui.mouse.disable-shadow",
    "ui.visualfx.best-performance",
    "ui.startup.delay-disable",
    "ui.menu-show-delay.zero",
    "process.system.responsiveness",
    "process.priority-separation.foreground",
    "process.power-throttling.disable",
    "process.usb-power-mgmt.disable",
    "process.hid-power-mgmt.disable",
    "process.hags.enable",
    "process.windows-search.disable",
    "process.sysmain.disable",
    "process.edge.background-disable",
    "process.onedrive.autostart-disable",
    "process.discord.autostart-disable",
    "privacy.telemetry.disable",
    "privacy.cortana.disable",
    "privacy.diagtrack.disable",
    "privacy.start-bing-search.disable",
    "audio.system-sounds.none",
    "net.throttling.disable"
  ]
}

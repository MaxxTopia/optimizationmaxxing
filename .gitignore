# Tauri updater signing keypair — public key goes in tauri.conf.json,
# private key + .pub are kept local; CI uses TAURI_SIGNING_PRIVATE_KEY
# secret (paste of the file's contents) to sign release artifacts.
.tauri-signing-key
.tauri-signing-key.pub
